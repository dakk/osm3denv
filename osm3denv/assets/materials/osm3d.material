// Area materials: one shared shader (osm3d_area_fs) with a per-material
// ``area_class`` uniform picking the procedural pattern. Depth_bias is layered
// so overlapping areas pick the more specific class.

material osm3d/vegetation
{
    technique { pass {
        depth_bias 30 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_area_fs { param_named area_class int 1 }
    } }
}

material osm3d/residential
{
    technique { pass {
        depth_bias 40 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_area_fs { param_named area_class int 2 }
    } }
}

material osm3d/commercial
{
    technique { pass {
        depth_bias 45 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_area_fs { param_named area_class int 3 }
