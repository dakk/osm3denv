// Paved city square / pedestrian plaza / marketplace (area_class=8).
// Reuses the PavingStones pack — the shader tints slightly cooler for
// a stone-plaza look vs. residential/commercial pavement.
material osm3d/paved_square_pbr
{
    technique { pass {
        depth_bias 50 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_area_pbr_fs { param_named area_class int 8 }
        texture_unit area_albedo
        {
            texture PavingStones012_2K-PNG_Color.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit area_normal
        {
            texture PavingStones012_2K-PNG_NormalGL.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit area_rough
        {
            texture PavingStones012_2K-PNG_Roughness.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit area_ao
        {
            texture PavingStones012_2K-PNG_AmbientOcclusion.png
            filtering trilinear
            tex_address_mode wrap
        }
    } }
}

// Procedural-fallback square (no paving-stones pack cached).
material osm3d/paved_square
{
    technique { pass {
        depth_bias 50 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_area_fs { param_named area_class int 8 }
    } }
}

material osm3d/trees
{
    technique
    {
        pass
        {
            vertex_program_ref osm3d_trees_vs { }
            fragment_program_ref osm3d_trees_fs { }
        }
    }
}

// Sky dome. Drawn first (SKIES_EARLY), with depth writes off and culling
// flipped so we see the inside of the inverted cube.
material osm3d/sky
{
    technique
    {
        pass
        {
            lighting off
            depth_write off
            depth_check on
            cull_hardware none
            vertex_program_ref osm3d_sky_vs { }
            fragment_program_ref osm3d_sky_fs { }
        }
    }
}
