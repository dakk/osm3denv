// PBR variants. Each binds a class-appropriate ambientCG pack into the four
// generic sampler slots of osm3d_area_pbr_fs. materials.py falls back to the
// procedural variant above whenever the pack isn't cached on disk.

material osm3d/vegetation_pbr
{
    technique { pass {
        depth_bias 30 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_area_pbr_fs { param_named area_class int 1 }
        texture_unit area_albedo
        {
            texture Grass004_2K-PNG_Color.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit area_normal
        {
            texture Grass004_2K-PNG_NormalGL.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit area_rough
        {
            texture Grass004_2K-PNG_Roughness.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit area_ao
