material osm3d/roads
{
    technique
    {
        pass
        {
            depth_bias 10 5
            vertex_program_ref osm3d_terrain_vs { }
            fragment_program_ref osm3d_asphalt_fs { }
        }
    }
}

// PBR variant of osm3d/roads. References files shipped inside the ambientCG
// Asphalt026A 2K-PNG pack, which osm3denv.fetch.textures downloads to
// ~/.cache/osm3denv/textures/Asphalt026A_2K-PNG/ before the viewer starts.
// materials.roads() picks this material when those files are present.
material osm3d/roads_pbr
{
    technique
    {
        pass
        {
            depth_bias 10 5
            vertex_program_ref osm3d_terrain_vs { }
            fragment_program_ref osm3d_asphalt_pbr_fs { }
            texture_unit albedo
        {
            texture Asphalt026A_2K-PNG_Color.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit normal
        {
            texture Asphalt026A_2K-PNG_NormalGL.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit rough
        {
            texture Asphalt026A_2K-PNG_Roughness.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit ao
        {
            texture Asphalt026A_2K-PNG_AmbientOcclusion.png
            filtering trilinear
            tex_address_mode wrap
        }
        }
    }
}

// Per-kind road materials. Each binds a surface pack into the four generic
// sampler slots of osm3d_road_pbr_fs and picks a marking_mode:
//   0 = none, 1 = dashed white centreline, 2 = double-yellow + lane dashes.

material osm3d/roads/asphalt_major
{
    technique { pass {
        depth_bias 10 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_road_pbr_fs { param_named marking_mode int 2 }
        texture_unit surface_albedo
        {
            texture Asphalt026A_2K-PNG_Color.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit surface_normal
        {
            texture Asphalt026A_2K-PNG_NormalGL.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit surface_rough
        {
            texture Asphalt026A_2K-PNG_Roughness.png
            filtering trilinear
            tex_address_mode wrap
        }
        texture_unit surface_ao
        {
            texture Asphalt026A_2K-PNG_AmbientOcclusion.png
            filtering trilinear
            tex_address_mode wrap
        }
    } }
}

material osm3d/roads/asphalt_minor
{
    technique { pass {
        depth_bias 10 5
        vertex_program_ref osm3d_terrain_vs { }
        fragment_program_ref osm3d_road_pbr_fs { param_named marking_mode int 1 }
