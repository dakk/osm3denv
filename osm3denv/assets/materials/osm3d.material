            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit grass_ao
        {
            texture Grass004_2K-PNG_AmbientOcclusion.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit rock_albedo
        {
            texture Rock030_2K-PNG_Color.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit rock_normal
        {
            texture Rock030_2K-PNG_NormalGL.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit rock_rough
        {
            texture Rock030_2K-PNG_Roughness.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit rock_ao
        {
            texture Rock030_2K-PNG_AmbientOcclusion.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit sand_albedo
        {
            texture Sand006_2K-PNG_Color.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit sand_normal
        {
            texture Sand006_2K-PNG_NormalGL.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit sand_rough
        {
            texture Sand006_2K-PNG_Roughness.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit sand_ao
        {
            texture Sand006_2K-PNG_AmbientOcclusion.png
            filtering trilinear
            tex_address_mode wrap
        }
        }
    }
}

material osm3d/water
{
    technique
    {
        pass
        {
            scene_blend alpha_blend
            depth_write off
            depth_bias 1 1
            vertex_program_ref osm3d_water_vs { }
            fragment_program_ref osm3d_water_fs { }
        }
    }
}

