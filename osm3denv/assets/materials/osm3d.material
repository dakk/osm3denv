// Textured materials for osm3denv. Custom-shader materials (terrain, water)
// reference programs from osm3d.program; everything else is fixed-function +
// one texture unit — Ogre's RTShader System auto-generates shaders for them.

material osm3d/terrain
{
    technique
    {
        pass
        {
            vertex_program_ref osm3d_terrain_vs { }
            fragment_program_ref osm3d_terrain_fs { }
        }
    }
}

material osm3d/terrain_pbr
{
    technique
    {
        pass
        {
            vertex_program_ref osm3d_terrain_vs { }
            fragment_program_ref osm3d_terrain_pbr_fs { }
            texture_unit grass_albedo
        {
            texture Grass004_2K-PNG_Color.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit grass_normal
        {
            texture Grass004_2K-PNG_NormalGL.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit grass_rough
        {
            texture Grass004_2K-PNG_Roughness.png
            filtering trilinear
            tex_address_mode wrap
        }
            texture_unit grass_ao
        {
            texture Grass004_2K-PNG_AmbientOcclusion.png
            filtering trilinear
            tex_address_mode wrap
        }
        }
    }
}

material osm3d/terrain_pbr_full
{
    technique
    {
        pass
        {
            vertex_program_ref osm3d_terrain_vs { }
            fragment_program_ref osm3d_terrain_pbr_full_fs { }
